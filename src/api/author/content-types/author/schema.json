{
  "kind": "collectionType",
  "collectionName": "authors",
  "info": {
    "singularName": "author",
    "pluralName": "authors",
    "displayName": "Author"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "description": {
      "type": "blocks",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "image": {
      "type": "media",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "facebookProfile": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "linkedinProfile": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "slots": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::slot.slot",
      "mappedBy": "author"
    },
    "slotThemes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::slot-theme.slot-theme",
      "mappedBy": "author"
    },
    "providers": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::provider.provider",
      "mappedBy": "author"
    },
    "slotMechanics": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::slot-mechanic.slot-mechanic",
      "mappedBy": "author"
    },
    "roulettes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::roulette.roulette",
      "mappedBy": "author"
    },
    "rouletteMechanics": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::roulette-mechanic.roulette-mechanic",
      "mappedBy": "author"
    }
  }
}
